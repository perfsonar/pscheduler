{
    "#": "This gets merged into every version as #/local.",
    "local": {},

    "#": "The zeroth element of this is always null since there is no version 0.",
    "versions": [
	null,

	{
            "type": "object",
            "properties": {
		"schema":           { "$ref": "#/pScheduler/Cardinal" },
		"duration":         { "$ref": "#/pScheduler/Duration" },
		"host":             { "$ref": "#/pScheduler/Host" },
		"host-node":        { "$ref": "#/pScheduler/URLHostPort" },
		"interval":         { "$ref": "#/pScheduler/Duration" },
		"parting-comment":  { "$ref": "#/pScheduler/String" },
		"starting-comment": { "$ref": "#/pScheduler/String" }
            },
	    "additionalProperties": false,
            "required": [
		"duration"
            ]
	}
    ]
}
