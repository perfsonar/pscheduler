{
    "#": "This gets merged into every version as #/local.",
    "local": {},

    "#": "The zeroth element of this is always null since there is no version 0.",
    "versions": [
	null,

        {
            "type": "object",
            "properties": {
                "schema":       { "$ref": "#/pScheduler/Cardinal" },
                "source":       { "$ref": "#/pScheduler/Host" },
                "source-node":  { "$ref": "#/pScheduler/Host" },
                "dest":         { "$ref": "#/pScheduler/Host" },
                "port":         { "$ref": "#/pScheduler/IPPort" }
            },
            "required": [
                "dest"
            ],
            "additionalProperties": false
        },

	{
            "type": "object",
            "properties": {
                "schema":       { "$ref": "#/pScheduler/Cardinal", "enum": [ 2 ] },
                "source":       { "$ref": "#/pScheduler/Host" },
                "source-node":  { "$ref": "#/pScheduler/Host" },
                "dest":         { "$ref": "#/pScheduler/Host" },
                "ip-version":   { "$ref": "#/pScheduler/ip-version" },
                "port":         { "$ref": "#/pScheduler/IPPort" }
            },
            "required": [
		"schema",
                "dest"
            ],
            "additionalProperties": false
        }
    ]
}
