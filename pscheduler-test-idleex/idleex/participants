#!/usr/bin/env python3
#
# Participant list generator for 'idleex' task spec
#
# Input is a test spec, assumed to have been validated by spec-is-valid.
#
# Output is a list of hostnames or IPs that are participating.
#

import pscheduler

json = pscheduler.plugin_spec_is_valid('test', return_if_valid=True)

null_reason = None

host = json.get("host-node", json.get("host", None))
if host is None:
    null_reason = "No source specified"

participants = [ host ]

result = {
    "participants": participants
}

if null_reason is not None:
    result["reason"] = null_reason


pscheduler.succeed_json(result)
