#!/usr/bin/env python3
#
# Convert a test specification to command-line options

import pscheduler

spec = pscheduler.plugin_spec_is_valid('test', return_if_valid=True)

result = pscheduler.speccli_build_args(spec, 
                                       strings=[
        # Strings
        ( 'count', 'count' ),
        ( 'dest', 'dest' ),
        ( 'flow-label', 'flow-label' ),
        ( 'interval', 'interval' ),
        ( 'ip-version', 'ip-version' ),
        ( 'source', 'source' ),
        ( 'source-node', 'source-node' ),
        ( 'ip-tos', 'ip-tos' ),
        ( 'length', 'length' ),
        ( 'ttl', 'ttl' ),
        ( 'deadline', 'deadline' ),
        ( 'timeout', 'timeout' ),
        ( 'port', 'port' ),
        ( 'protocol', 'protocol' ),
        ],
                                       bools=[
        ( 'suppress-loopback', 'suppress-loopback' ),
        ( 'fragment', 'fragment' ),
        ( 'hostnames', 'hostnames' )
        ])


pscheduler.succeed_json(result)
