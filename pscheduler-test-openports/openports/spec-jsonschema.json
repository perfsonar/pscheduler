{
    "#": "This gets merged into every version as #/local.",
    "local": {
	"portlist": {
            "type": "string",
	    "pattern" : "^(6553[0-5]|655[0-2][0-9]|65[0-4][0-9]{2}|6[0-4][0-9]{3}|[1-5][0-9]{4}|[0-9]{1,4})((,(6553[0-5]|655[0-2][0-9]|65[0-4][0-9]{2}|6[0-4][0-9]{3}|[1-5][0-9]{4}|[0-9]{1,4}))|(-(6553[0-5]|655[0-2][0-9]|65[0-4][0-9]{2}|6[0-4][0-9]{3}|[1-5][0-9]{4}|[0-9]{1,4})))*$"
        },
        "HostOrCIDR": {
            "oneOf": [
                { "$ref": "#/pScheduler/IPCIDR" },
                { "$ref": "#/pScheduler/Host" }
            ]
	}
    },

    "#": "The zeroth element of this is always null since there is no version 0.",
    "versions": [
	null,

	{
            "type": "object",
            "properties": {
                "schema":         { "$ref": "#/pScheduler/Cardinal" },
                "network":        { "$ref": "#/local/HostOrCIDR" },
                "source":         { "$ref": "#/pScheduler/Host" },
                "services":       { "$ref": "#/pScheduler/Boolean" },
                "ports":          { "$ref": "#/local/portlist" },
                "timeout":        { "$ref": "#/pScheduler/Duration" },
                "source-node":    { "$ref": "#/pScheduler/URLHostPort"}
            },

            "required": [
                "network"
            ],
	    "additionalProperties": false
        }
    ]
}
